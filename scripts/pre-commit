#!/bin/bash
# Pre-commit hook for Pulsar
# Scans staged files for secrets using gitleaks

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check for binary files in staged changes
echo -e "${YELLOW}Checking for binary files...${NC}"
BINARY_FILES=""
for file in $(git diff --cached --name-only --diff-filter=ACM); do
    if [ -f "$file" ] && file "$file" | grep -qE 'ELF|Mach-O|PE32|executable.*not.*script'; then
        BINARY_FILES="$BINARY_FILES\n  $file"
    fi
done

if [ -n "$BINARY_FILES" ]; then
    echo -e "${RED}Binary files detected in staged changes:${NC}"
    echo -e "${RED}${BINARY_FILES}${NC}"
    echo -e "${YELLOW}Remove them with: git reset HEAD <file>${NC}"
    exit 1
fi
echo -e "${GREEN}No binary files detected.${NC}"

echo -e "${YELLOW}Running gitleaks secret scan...${NC}"

# Check if gitleaks is installed
if ! command -v gitleaks &> /dev/null; then
    # Try common installation paths
    if [ -x "$HOME/.local/bin/gitleaks" ]; then
        GITLEAKS="$HOME/.local/bin/gitleaks"
    else
        echo -e "${RED}Error: gitleaks is not installed${NC}"
        echo "Install with: curl -sSfL https://github.com/gitleaks/gitleaks/releases/download/v8.18.4/gitleaks_8.18.4_linux_x64.tar.gz | tar -xz -C ~/.local/bin"
        exit 1
    fi
else
    GITLEAKS="gitleaks"
fi

# Get the root of the git repository
REPO_ROOT=$(git rev-parse --show-toplevel)

# Run gitleaks on staged changes
if [ -f "$REPO_ROOT/.gitleaks.toml" ]; then
    $GITLEAKS protect --staged --config "$REPO_ROOT/.gitleaks.toml" --verbose
else
    $GITLEAKS protect --staged --verbose
fi

if [ $? -eq 0 ]; then
    echo -e "${GREEN}No secrets detected.${NC}"
else
    echo -e "${RED}Secrets detected! Commit blocked.${NC}"
    echo -e "${YELLOW}Review the findings above and remove any secrets before committing.${NC}"
    exit 1
fi
